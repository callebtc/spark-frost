{
  "name": "spark-frost",
  "description": "A Spark L2 wallet with FROST threshold signatures",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "homepage": "https://github.com/callebtc/spark-frost",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callebtc/spark-frost.git"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "yarn workspace @buildonspark/spark-sdk build",
    "types": "yarn workspace @buildonspark/spark-sdk types && yarn workspace @buildonspark/nodejs-scripts types && yarn workspace spark-frost-demo types && yarn workspace spark-frost-dkg types",
    "test": "yarn workspace @buildonspark/spark-sdk test-cmd src/tests/threshold-signer.test.ts",
    "demo:create-wallet": "yarn workspace spark-frost-demo create-wallet",
    "demo:normal-wallet": "yarn workspace spark-frost-demo normal-wallet",
    "demo:claim-deposit": "yarn workspace spark-frost-demo claim-deposit",
    "demo:transfer": "yarn workspace spark-frost-demo transfer",
    "demo:pay-invoice": "yarn workspace spark-frost-demo pay-invoice",
    "demo:lightning": "yarn workspace spark-frost-demo lightning",
    "demo:pipeline": "yarn workspace spark-frost-demo pipeline",
    "dkg:keygen": "yarn workspace spark-frost-dkg keygen",
    "dkg:spark-smoke": "yarn workspace spark-frost-dkg spark-smoke",
    "dkg:pipeline": "yarn workspace spark-frost-dkg pipeline",
    "dkg:ceremony": "yarn workspace spark-frost-dkg ceremony",
    "wallet:address": "yarn workspace @buildonspark/nodejs-scripts get-spark-address",
    "wallet:balance": "yarn workspace @buildonspark/nodejs-scripts get-balance"
  },
  "workspaces": [
    "dkg",
    "demo",
    "examples/*",
    "packages/*"
  ],
  "packageManager": "yarn@4.13.0"
}
